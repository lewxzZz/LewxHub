-- Hàm tạo nút dạng tròn (không dùng Tween để tránh lỗi)
local function createBtn(text, yPos, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 220, 0, 48)
    btn.Position = UDim2.new(0.5, -110, 0, yPos)
    btn.BackgroundColor3 = color or Color3.fromRGB(50, 50, 80)
    btn.BackgroundTransparency = 0
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamSemibold
    btn.BorderSizePixel = 0
    btn.Parent = mainFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(1, 0)
    btnCorner.Parent = btn
    
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- Chức năng Banana
local function bananaSell()
    for i = 1, 20 do
        pcall(function()
            local args = {[1] = "SellFruit", [2] = "Banana"}
            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
        end)
        task.wait(0.3)
    end
    print("Đã bán 20 Banana")
end

-- Auto Farm
local farmRunning = false
local farmConnection
local function toggleFarm()
    farmRunning = not farmRunning
    if farmRunning then
        print("Bắt đầu Farm")
        farmConnection = game:GetService("RunService").Heartbeat:Connect(function()
            pcall(function()
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        LocalPlayer.Character.HumanoidRootPart.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 0, 4)
                        task.wait()
                        game:GetService("VirtualInputManager"):SendKeyEvent(true, "X", false, game)
                        task.wait(0.05)
                        game:GetService("VirtualInputManager"):SendKeyEvent(false, "X", false, game)
                        break
                    end
                end
            end)
        end)
    else
        if farmConnection then farmConnection:Disconnect() end
        print("Dừng Farm")
    end
end

-- Auto Boss
local function autoBoss()
    for _, v in pairs(workspace.Enemies:GetChildren()) do
        if v.Name == "Boss" and v:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5)
            task.wait(0.5)
            for i = 1, 5 do
                game:GetService("VirtualInputManager"):SendKeyEvent(true, "X", false, game)
                task.wait(0.1)
                game:GetService("VirtualInputManager"):SendKeyEvent(false, "X", false, game)
                task.wait(0.2)
            end
        end
    end
end

-- Teleport đảo
local function teleportIsland()
    for _, v in pairs(workspace:GetChildren()) do
        if v.Name == "Jungle" and v:FindFirstChild("Spawn") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = v.Spawn.CFrame * CFrame.new(0, 5, 0)
            break
        end
    end
end

-- Mua chỉ số
local function buyStat()
    pcall(function()
        local args = {[1] = "BuyStat", [2] = "Melee"}
        game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
    end)
end

